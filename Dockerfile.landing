# syntax=docker/dockerfile:1

FROM node:20-bookworm-slim

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY artifacts/kilo-landing ./artifacts/kilo-landing
COPY artifacts/kilo-app/public ./artifacts/kilo-app/public

RUN pnpm install --frozen-lockfile --filter @workspace/kilo-landing...
RUN pnpm --filter @workspace/kilo-landing run build

WORKDIR /app/artifacts/kilo-landing

ENV NODE_ENV=production
EXPOSE 8080

CMD ["node", "src/server.mjs"]
