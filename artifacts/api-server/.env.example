# قالب متغيرات البيئة — لا تضع قيماً حقيقية هنا أبداً
# انسخ إلى .env محلياً: cp .env.example .env

# PostgreSQL (محلي: kilo_app | Railway: يُحقَن تلقائياً من خدمة Postgres)
DATABASE_URL=postgresql://postgres:<YOUR_POSTGRES_PASSWORD>@localhost:5432/kilo_app

# سر الجلسة — ولّد قيمة عشوائية طويلة (32+ حرف)
# مثال: openssl rand -hex 32
SESSION_SECRET=<GENERATE_A_LONG_RANDOM_SECRET>

# منفذ API محلياً (Railway يستخدم PORT تلقائياً)
API_PORT=8081

# CORS — محلي
CORS_ORIGIN=http://localhost:5174

# كلمة مرور المدير الأول (تطوير محلي فقط)
KILO_DEV_ADMIN_PASSWORD=<LOCAL_DEV_ONLY_PASSWORD>

# اختياري: إعادة تهيئة قاعدة البيانات مرة واحدة
# KILO_DEV_RESET=1

# --- إنتاج (تُضبط في Railway Variables فقط، لا في الملفات) ---
# NODE_ENV=production
# API_PUBLIC_URL=https://app.kilo-sa.com
# CORS_ORIGIN=https://app.kilo-sa.com
# KILO_ADMIN_EMAIL=admin@kilo-sa.com
# KILO_ADMIN_PASSWORD=<STRONG_PASSWORD_FOR_FIRST_ADMIN>
# Storage Bucket (يُحقَن تلقائياً عند ربط Bucket بالخدمة):
# AWS_ENDPOINT_URL=https://storage.railway.app
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET_NAME=...
# AWS_DEFAULT_REGION=auto
